# SAM.gov API key — get one free at https://sam.gov/content/home
# Supports comma-separated keys for rotation (e.g., key1,key2,key3)
SAMGOV_API_KEY=your-api-key-here

# Auth secret for session cookies (32+ random chars)
AUTH_SECRET=change-me-to-a-random-32-char-string

# Resend API key for email alerts (https://resend.com)
# RESEND_API_KEY=re_xxxxxxxxx
# RESEND_FROM_EMAIL=GovScout <alerts@yourdomain.com>

# Target recipient for `govscout testemail` (required only for that command)
# TEST_EMAIL_TO=you@example.com

# Optional: SQLite database path (default: ./govscout.db)
# GOVSCOUT_DB=./govscout.db

# Optional: Web server port (default: 8080)
# PORT=8080
